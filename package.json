{
  "name": "svmmon-mcp",
  "version": "1.1.1",
  "description": "Public MCP server for Svmmon — generate TikTok slideshows from Claude and other MCP clients. Thin wrapper over the Svmmon /api/v1 REST API.",
  "license": "MIT",
  "author": "Corey Wessel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coreywessel/svmmon-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/coreywessel/svmmon-mcp/issues"
  },
  "homepage": "https://github.com/coreywessel/svmmon-mcp#readme",
  "type": "module",
  "bin": {
    "svmmon-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
